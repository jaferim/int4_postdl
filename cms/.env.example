# Copy this file to ".env" before running the CMS locally:  cp .env.example .env
# .env is gitignored, so real secrets never get committed.
#
# IMPORTANT: the values below are PLACEHOLDERS. For local development you can put
# any random strings in the secret fields (they only sign local sessions/tokens).
# Generate strong ones quickly with:
#   node -e "console.log(require('crypto').randomBytes(16).toString('base64'))"
# APP_KEYS takes a comma-separated list (4 values is typical).

# ---- Server ----------------------------------------------------------------
HOST=0.0.0.0
PORT=1337

# ---- Secrets (fill with random values; see note above) ---------------------
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=replace-me
ADMIN_JWT_SECRET=replace-me
TRANSFER_TOKEN_SALT=replace-me
JWT_SECRET=replace-me
ENCRYPTION_KEY=replace-me

# ---- Database --------------------------------------------------------------
# Local dev uses SQLite (zero setup, a single file on disk). The production
# deploy overrides these with DATABASE_CLIENT=postgres + DATABASE_URL on Render.
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db
