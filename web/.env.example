# Copy this file to .env.local and restart the dev server (Vite reads env files
# only at startup). .env.local is gitignored.

# Data source for the canvas. "true" reads live from the hosted Strapi; anything
# else (unset, empty, "false") falls back to the committed seed.json snapshot,
# so local dev works offline with no CMS running.
VITE_USE_API=true

# Base URL of the Strapi CMS (no trailing /api; the app appends it). Leave the
# hosted URL here for frontend work, or point at http://localhost:1337 to read a
# local Strapi instance.
VITE_STRAPI_URL=https://int4-team15.onrender.com
