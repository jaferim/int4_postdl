# Copy this file to ".env" and fill in STRAPI_TOKEN below.
# (.env is gitignored so your token never gets committed.)

# AI runs LOCALLY via Ollama — no API key, no account, no billing.
# Setup once:  brew install ollama && brew services start ollama
#              ollama pull qwen2.5:7b && ollama pull nomic-embed-text
# These are optional overrides (defaults shown):
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b           # used by tag-facets.js
# OLLAMA_EMBED_MODEL=nomic-embed-text   # used by embed-and-link.js

# LOCAL Strapi. Keep this pointed at localhost so these bulk scripts don't
# eat into the cloud free-plan limits. You'll `strapi transfer` the data up later.
STRAPI_URL=http://localhost:1337

# Strapi API token: Strapi admin -> Settings -> API Tokens -> Create new token.
# Either pick "Full access" (simplest for a local one-time run), or "Custom" with:
#   Facet: find, update   |   Tag: find   |   Edge: create
# (These are the token's OWN permissions, not the public role.)
STRAPI_TOKEN=your-strapi-api-token-here

# Optional. Leave unset (or "true") for a safe preview that writes NOTHING.
# Set to "false" only when you're ready to actually write to Strapi.
# DRY_RUN=false
